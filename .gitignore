!/tmp/tests/.gitkeep

# Cache contents
/tmp/cache/*
!/tmp/cache/.gitkeep

# Sessions
/tmp/sessions/*
!/tmp/sessions/.gitkeep

# Test files
/tmp/tests/*
!/tmp/tests/.gitkeep

# Composer dependencies
/vendor/

